    print("EXPERIMENT SUMMARY")
    print("=" * 70)
    print(f"Total episodes: {len(trainer.metrics['returns'])}")
    print(f"Best return: {max(trainer.metrics['returns']):.2f}")
    if len(trainer.metrics['returns']) >= 20:
        print(f"Final average return (last 20): {np.mean(trainer.metrics['returns'][-20:]):.2f}")
    print(f"Evaluation average: {np.mean(eval_returns):.2f} ± {np.std(eval_returns):.2f}")
    print(f"Final buffer size: {len(trainer.replay_buffer)}")
    print(f"Final epsilon: {trainer.agent.epsilon:.3f}")

    print("\n✅ Experiment completed successfully!")

    return trainer, eval_returns


