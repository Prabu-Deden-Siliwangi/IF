class SimpleDataGenerator:
    """Simplified data generator for testing."""

    def __init__(self, n_samples=5000, window_size=50, n_views=3, view_dims=[4, 4, 4]):
        self.n_samples = n_samples
        self.window_size = window_size
        self.n_views = n_views
        self.view_dims = view_dims

    def generate_data(self):
        """Generate synthetic multi-view data."""
        data = []
        targets = []

        for _ in range(self.n_samples - self.window_size):
            window_views = {}
            for v in range(self.n_views):
                # Generate random time series
                seq = np.random.randn(self.window_size, self.view_dims[v])
                window_views[v] = seq.astype(np.float32)
            data.append(window_views)

            # Generate target (energy consumption)
            target = np.random.randn(5)  # 5 horizons
            targets.append(target.astype(np.float32))

        return data, targets

# %% [markdown]
# ## 3. QAFusion-MH Model (Simplified and Fixed)

# %%
class SimpleEncoder(nn.Module):
    """Simple encoder for each view."""
    def __init__(self, input_dim, hidden_dim):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True)

    def forward(self, x):
        # x: (batch, seq_len, input_dim)
        out, (h, _) = self.lstm(x)
        return h[-1]  # (batch, hidden_dim)


class QAFusionMH(nn.Module):
    """Quality-Aware Multi-View Fusion Model."""

    def __init__(self, n_views=3, view_dims=[4, 4, 4], hidden_dim=64, n_horizons=5):
        super().__init__()
        self.n_views = n_views
        self.hidden_dim = hidden_dim
        self.n_horizons = n_horizons

        # Encoders for each view
        self.encoders = nn.ModuleList([
            SimpleEncoder(view_dims[v], hidden_dim) for v in range(n_views)
        ])

        # Quality estimators (simple)
        self.quality_net = nn.ModuleList([
            nn.Sequential(
                nn.Linear(hidden_dim + 4, 32),
                nn.ReLU(),
                nn.Linear(32, 1),
                nn.Sigmoid()
            ) for _ in range(n_views)
        ])

        # Gating network for fusion
        self.gating_net = nn.ModuleList([
            nn.Sequential(
                nn.Linear(hidden_dim + 1, 32),
                nn.ReLU(),
                nn.Linear(32, 1)
            ) for _ in range(n_views)
        ])

        # Forecasting head
        self.forecast_head = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Linear(64, n_horizons)
        )

    def compute_quality_features(self, x):
        """Compute simple quality features."""
        batch_size = x.shape[0]
        # Missing ratio (simulated)
        miss_ratio = torch.zeros(batch_size).to(x.device)
        # Reconstruction residual
        recon_residual = torch.rand(batch_size).to(x.device) * 0.1
        # Outlier score
        outlier_score = torch.rand(batch_size).to(x.device) * 0.1
        # Alignment score
        alignment = torch.ones(batch_size).to(x.device)

        return torch.stack([miss_ratio, recon_residual, outlier_score, alignment], dim=1)

    def forward(self, views, return_all=False):
        """
        Args:
            views: list of tensors, each (batch, seq_len, dim_v)
        """
        batch_size = views[0].shape[0]

        # Encode each view
        embeddings = []
        for v in range(self.n_views):
            h = self.encoders[v](views[v])  # (batch, hidden_dim)
            embeddings.append(h)

        # Compute quality scores
        quality_scores = []
        for v in range(self.n_views):
            quality_features = self.compute_quality_features(views[v])
            concat = torch.cat([embeddings[v], quality_features], dim=-1)
            q = self.quality_net[v](concat).squeeze(-1)
            quality_scores.append(q)

        # Compute gating weights
        weights = []
        logits = []
        for v in range(self.n_views):
            concat = torch.cat([embeddings[v], quality_scores[v].unsqueeze(-1)], dim=-1)
            logit = self.gating_net[v](concat).squeeze(-1)
            logits.append(logit)

        # Softmax over views
        logits_stack = torch.stack(logits, dim=1)  # (batch, n_views)
        weights = torch.softmax(logits_stack, dim=1)  # (batch, n_views)

        # Weighted fusion
        fused_state = torch.zeros(batch_size, self.hidden_dim).to(views[0].device)
        for v in range(self.n_views):
            fused_state = fused_state + weights[:, v:v+1] * embeddings[v]

        # Multi-horizon forecasting
        predictions = self.forecast_head(fused_state)  # (batch, n_horizons)

        if return_all:
            return fused_state, predictions, weights, quality_scores
        return fused_state, predictions

# %% [markdown]
# ## 4. Conditional GAN (Fixed)

# %%
class SimpleGAN(nn.Module):
    """Simplified Conditional GAN."""

    def __init__(self, state_dim, action_dim, hidden_dim=64):
        super().__init__()
        self.state_dim = state_dim
        self.action_dim = action_dim

        # Generator: (state, action, noise) -> (reward, next_state)
        gen_input = state_dim + action_dim + 16
        self.generator = nn.Sequential(
            nn.Linear(gen_input, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, 1 + state_dim)  # reward + next_state
        )

        # Discriminator: (state, action, reward, next_state) -> real/fake
        disc_input = state_dim + action_dim + 1 + state_dim
        self.discriminator = nn.Sequential(
            nn.Linear(disc_input, hidden_dim),
            nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, hidden_dim),
            nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, 1),
            nn.Sigmoid()
        )

    def encode_action(self, action, batch_size):
        """Convert action indices to one-hot."""
        action_onehot = torch.zeros(batch_size, self.action_dim).to(action.device)
        action_onehot.scatter_(1, action.unsqueeze(-1), 1)
        return action_onehot

    def generate(self, state, action):
        """Generate synthetic reward and next_state."""
        batch_size = state.shape[0]
        noise = torch.randn(batch_size, 16).to(state.device)
        action_onehot = self.encode_action(action, batch_size)

        concat = torch.cat([state, action_onehot, noise], dim=-1)
        output = self.generator(concat)

        reward = output[:, 0]  # (batch,)
        next_state = output[:, 1:]  # (batch, state_dim)

        return reward, next_state

    def discriminate(self, state, action, reward, next_state):
        """Discriminate real vs fake."""
        batch_size = state.shape[0]
        action_onehot = self.encode_action(action, batch_size)

        concat = torch.cat([state, action_onehot, reward.unsqueeze(-1), next_state], dim=-1)
        return self.discriminator(concat).squeeze(-1)

