def run_experiment():
    """Run the complete experiment."""
    print("=" * 70)
    print("QAFusion-MH + GAN-Q-Learning - Complete Experiment")
    print("=" * 70)

    # 1. Generate data
    print("\n[1] Generating training data...")
    data_gen = SimpleDataGenerator(n_samples=2000, window_size=30, n_views=3, view_dims=[4, 4, 4])
    train_data, train_targets = data_gen.generate_data()
    print(f"Generated {len(train_data)} training samples")

    # 2. Initialize trainer
    print("\n[2] Initializing models...")
    trainer = Trainer(state_dim=4, action_dim=4, hidden_dim=32, n_views=3, view_dims=[4, 4, 4])

    # 3. Train QAFusion-MH
    trainer.train_qafusion(train_data, train_targets, epochs=15, batch_size=16)

    # 4. Initialize environment and collect transitions
    print("\n[3] Collecting real transitions...")
    env = EnergyEnvironment(max_steps=50)
    transitions = trainer.collect_transitions(env, n_episodes=15)

    # 5. Train GAN
    trainer.train_gan(transitions, epochs=20, batch_size=16)

    # 6. Train policy with quality-controlled replay
    trainer.train_policy(env, n_episodes=60, synthetic_interval=10, synthetic_count=200)

