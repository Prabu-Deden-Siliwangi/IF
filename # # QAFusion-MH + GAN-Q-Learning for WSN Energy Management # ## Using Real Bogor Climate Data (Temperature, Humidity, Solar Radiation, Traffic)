class ConditionalGAN(nn.Module):
    """Conditional GAN for synthetic transition generation."""

    def __init__(self, state_dim, action_dim, hidden_dim=128):
        super().__init__()
        self.state_dim = state_dim
        self.action_dim = action_dim

        # Generator: (state, action_onehot, noise) -> (reward, next_state)
        gen_input = state_dim + action_dim + 32
        self.generator = nn.Sequential(
            nn.Linear(gen_input, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, 1 + state_dim)
        )

        # Discriminator: (state, action_onehot, reward, next_state) -> real/fake
        disc_input = state_dim + action_dim + 1 + state_dim
        self.discriminator = nn.Sequential(
            nn.Linear(disc_input, hidden_dim),
            nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, hidden_dim),
            nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, 1),
            nn.Sigmoid()
        )

    def _one_hot(self, action, batch_size):
        action_onehot = torch.zeros(batch_size, self.action_dim).to(action.device)
        action_onehot.scatter_(1, action.unsqueeze(-1), 1)
        return action_onehot

    def generate(self, state, action):
        batch_size = state.shape[0]
        noise = torch.randn(batch_size, 32).to(state.device)
        action_onehot = self._one_hot(action, batch_size)

        concat = torch.cat([state, action_onehot, noise], dim=-1)
        output = self.generator(concat)

        return output[:, 0], output[:, 1:]  # reward, next_state

    def discriminate(self, state, action, reward, next_state):
        batch_size = state.shape[0]
        action_onehot = self._one_hot(action, batch_size)

        concat = torch.cat([state, action_onehot, reward.unsqueeze(-1), next_state], dim=-1)
        return self.discriminator(concat).squeeze(-1)


def train_gan(gan, transitions, epochs=50, batch_size=64):
    """Train GAN on real transitions."""
    g_optimizer = optim.Adam(gan.generator.parameters(), lr=0.001)
    d_optimizer = optim.Adam(gan.discriminator.parameters(), lr=0.001)

    for epoch in range(epochs):
        # Sample batch
        batch = random.sample(transitions, min(batch_size, len(transitions)))
        states = torch.tensor(np.stack([b[0] for b in batch]), dtype=torch.float32).to(device)
        actions = torch.tensor([b[1] for b in batch], dtype=torch.long).to(device)
        rewards = torch.tensor([b[2] for b in batch], dtype=torch.float32).to(device)
        next_states = torch.tensor(np.stack([b[3] for b in batch]), dtype=torch.float32).to(device)

        # Train discriminator
        for _ in range(2):
            real_out = gan.discriminate(states, actions, rewards, next_states)
            d_real_loss = -torch.log(real_out + 1e-8).mean()

            fake_reward, fake_next_state = gan.generate(states, actions)
            fake_out = gan.discriminate(states, actions, fake_reward.detach(), fake_next_state.detach())
            d_fake_loss = -torch.log(1 - fake_out + 1e-8).mean()

            d_loss = d_real_loss + d_fake_loss
            d_optimizer.zero_grad()
            d_loss.backward()
            d_optimizer.step()

        # Train generator
        fake_reward, fake_next_state = gan.generate(states, actions)
        fake_out = gan.discriminate(states, actions, fake_reward, fake_next_state)
        g_loss = -torch.log(fake_out + 1e-8).mean()

        g_optimizer.zero_grad()
        g_loss.backward()
        g_optimizer.step()

        if (epoch + 1) % 25 == 0:
            print(f"GAN Epoch {epoch+1}/{epochs}, G Loss: {g_loss.item():.4f}")

    return gan

