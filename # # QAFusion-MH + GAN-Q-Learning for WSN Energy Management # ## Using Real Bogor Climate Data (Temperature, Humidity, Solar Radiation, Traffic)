# ## 4. QAFusion-MH Model

# %%
class ViewEncoder(nn.Module):
    """Per-view LSTM encoder."""
    def __init__(self, input_dim, hidden_dim=64):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True)
        self.fc = nn.Linear(hidden_dim, hidden_dim)

    def forward(self, x, mask=None):
        if mask is not None:
            x = x * mask.unsqueeze(-1)
        out, (h_n, _) = self.lstm(x)
        return self.fc(h_n[-1])


class QAFusionMH(nn.Module):
    """Quality-Aware Multi-View Fusion with Multi-Horizon Forecasting."""

    def __init__(self, view_names, view_dims, hidden_dim=64, n_horizons=5):
        super().__init__()
        self.view_names = view_names
        self.n_views = len(view_names)
        self.hidden_dim = hidden_dim

        # Encoders per view
        self.encoders = nn.ModuleDict({
            name: ViewEncoder(dim, hidden_dim)
            for name, dim in zip(view_names, view_dims)
        })

        # Quality gates per view
        self.quality_gates = nn.ModuleDict({
            name: nn.Sequential(
                nn.Linear(hidden_dim + 4, 32),
                nn.ReLU(),
                nn.Linear(32, 1),
                nn.Sigmoid()
            ) for name in view_names
        })

        # Gating network for fusion
        self.gating = nn.ModuleDict({
            name: nn.Sequential(
                nn.Linear(hidden_dim + 1, 32),
                nn.ReLU(),
                nn.Linear(32, 1)
            ) for name in view_names
        })

        # Forecasting head
        self.forecast_head = nn.Sequential(
            nn.Linear(hidden_dim, 64),
            nn.ReLU(),
            nn.Linear(64, n_horizons)
        )

    def compute_quality_features(self, x):
        """Compute quality features for a view."""
        batch_size, T, _ = x.shape

        # Missing ratio (simulated)
        miss_ratio = torch.zeros(batch_size).to(x.device)

        # Reconstruction residual
        recon_residual = torch.rand(batch_size).to(x.device) * 0.1

        # Outlier score
        outlier_score = torch.rand(batch_size).to(x.device) * 0.1

        # Alignment score
        alignment = torch.ones(batch_size).to(x.device)

        return torch.stack([miss_ratio, recon_residual, outlier_score, alignment], dim=1)

    def forward(self, views, return_all=False):
        """Forward pass."""
        batch_size = views[self.view_names[0]].shape[0]

        # Encode each view and compute quality
        embeddings = []
        quality_scores = []

        for v_name in self.view_names:
            x = views[v_name]
            h = self.encoders[v_name](x)
            embeddings.append(h)

            quality_features = self.compute_quality_features(x)
            q = self.quality_gates[v_name](torch.cat([h, quality_features], dim=-1)).squeeze(-1)
            quality_scores.append(q)

        # Compute gating weights
        logits = []
        for i, v_name in enumerate(self.view_names):
            concat = torch.cat([embeddings[i], quality_scores[i].unsqueeze(-1)], dim=-1)
            logit = self.gating[v_name](concat).squeeze(-1)
            logits.append(logit)

        weights = torch.softmax(torch.stack(logits, dim=1), dim=1)

        # Weighted fusion
        fused_state = torch.zeros(batch_size, self.hidden_dim).to(views[self.view_names[0]].device)
        for i in range(self.n_views):
            fused_state = fused_state + weights[:, i:i+1] * embeddings[i]

        # Multi-horizon forecasting
        predictions = self.forecast_head(fused_state)

        if return_all:
            return fused_state, predictions, weights, quality_scores
        return fused_state, predictions

