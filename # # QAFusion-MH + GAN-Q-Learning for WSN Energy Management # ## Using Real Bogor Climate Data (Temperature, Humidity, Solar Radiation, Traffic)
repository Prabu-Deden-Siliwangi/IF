# ## 3. Data Generator for WSN Multi-View Data (Using Bogor Climate Data)

# %%
class BogorWSNDataGenerator:
    """
    Generate WSN multi-view data using real Bogor climate data as environment view.
    """

    def __init__(self, climate_df, n_nodes=5, window_size=96, sampling_interval=5):
        """
        Args:
            climate_df: DataFrame with Bogor climate data (daily)
            n_nodes: Number of sensor nodes
            window_size: Window size in steps (T)
            sampling_interval: Minutes per step (default 5 min)
        """
        self.climate_df = climate_df.copy()
        self.n_nodes = n_nodes
        self.window_size = window_size
        self.sampling_interval = sampling_interval  # minutes

        # Upsample from daily to sampling_interval (5 min = 288 steps per day)
        self.steps_per_day = 24 * 60 // sampling_interval
        self.n_steps = len(climate_df) * self.steps_per_day

        # View dimensions
        self.view_dims = {
            'battery': 3,    # voltage, current, SoC
            'traffic': 2,    # packet_rate, queue_length
            'link': 3,       # RSSI, LQI, PDR
            'mac': 2,        # duty_cycle, tx_power
            'env': 3         # temp, humidity, solar_radiation (from Bogor data)
        }

    def interpolate_climate_to_steps(self):
        """Interpolate daily climate data to 5-minute steps."""
        # Create daily index
        daily_idx = pd.date_range(start=self.climate_df['Tanggal'].iloc[0],
                                  periods=len(self.climate_df), freq='D')

        # Create 5-minute index
        step_idx = pd.date_range(start=daily_idx[0],
                                 periods=self.n_steps,
                                 freq=f'{self.sampling_interval}min')

        # Interpolate each climate variable
        env_data = {}
        for var in ['Tavg', 'H_avg', 'ss', 'H', 'Tau']:
            daily_series = pd.Series(self.climate_df[var].values, index=daily_idx)
            # Resample to 5-minute steps with interpolation
            step_series = daily_series.reindex(step_idx).interpolate(method='linear')
            env_data[var] = step_series.values

        return env_data, step_idx

    def generate_clean_data(self):
        """Generate clean multi-view WSN data with Bogor climate as environment view."""

        # Get interpolated climate data
        env_data, step_idx = self.interpolate_climate_to_steps()

        data = {}

        for node in range(self.n_nodes):
            node_data = {}
            t = np.arange(self.n_steps)

            # 1. Battery view (influenced by time and harvesting from solar)
            # SoC decays with usage, recharges with solar radiation
            solar_radiation = env_data['H']
            base_soc = 0.8 + 0.2 * np.sin(2 * np.pi * t / self.steps_per_day)
            # Solar charging effect (normalized solar radiation)
            solar_charging = 0.3 * (solar_radiation / 25) * np.sin(2 * np.pi * t / self.steps_per_day)
            solar_charging = np.maximum(0, solar_charging)
            soc = base_soc + solar_charging - 0.0003 * t
            soc = np.clip(soc, 0.1, 1.0)

            voltage = 3.3 * soc + 0.1 * np.random.randn(self.n_steps)
            current = 10 + 5 * np.sin(2 * np.pi * t / self.steps_per_day) + 3 * np.random.randn(self.n_steps)

            node_data['battery'] = np.column_stack([voltage, current, soc])

            # 2. Traffic view (influenced by time of day and temperature)
            # Higher traffic during day and warmer temperatures
            hour_of_day = (t % self.steps_per_day) * self.sampling_interval / 60
            day_pattern = np.exp(-((hour_of_day - 12)**2) / (2 * 8**2)) * 30

            # Temperature influence (higher temp -> more activity)
            temp_influence = (env_data['Tavg'] - 24) * 2

            packet_rate = 15 + day_pattern + temp_influence + 5 * np.random.randn(self.n_steps)
            packet_rate = np.maximum(0, packet_rate)
            queue_length = np.maximum(0, 5 + 3 * np.sin(2 * np.pi * t / self.steps_per_day) + 2 * np.random.randn(self.n_steps))

            node_data['traffic'] = np.column_stack([packet_rate, queue_length])

            # 3. Link quality view (influenced by humidity and traffic)
            # Higher humidity -> worse link quality
            humidity = env_data['H_avg']
            rssi = -65 - 0.2 * (humidity - 70) + 3 * np.random.randn(self.n_steps)
            lqi = 60 - 0.5 * (humidity - 70) + 5 * np.random.randn(self.n_steps)
            pdr = 0.95 - 0.01 * (humidity - 70) - 0.005 * packet_rate + 0.05 * np.random.randn(self.n_steps)
            pdr = np.clip(pdr, 0.7, 1.0)

            node_data['link'] = np.column_stack([rssi, lqi, pdr])

            # 4. MAC/Routing view
            # Duty cycle adapts to traffic and solar availability
            duty_cycle = 0.2 + 0.15 * (packet_rate / 50) + 0.1 * (solar_radiation / 25)
            duty_cycle = np.clip(duty_cycle, 0.05, 0.8)
            tx_power = 10 + 5 * (packet_rate / 50) + 2 * np.random.randn(self.n_steps)
            tx_power = np.clip(tx_power, 5, 20)

            node_data['mac'] = np.column_stack([duty_cycle, tx_power])

            # 5. Environment view (from Bogor climate data)
            node_data['env'] = np.column_stack([
                env_data['Tavg'],   # Temperature
                env_data['H_avg'],  # Humidity
                solar_radiation     # Solar radiation (for harvesting)
            ])

            # Energy target (drain rate based on traffic and duty cycle)
            energy_drain = 0.03 + 0.02 * (packet_rate / 50) + 0.01 * duty_cycle + 0.01 * np.random.randn(self.n_steps)
            energy_drain = np.clip(energy_drain, 0.01, 0.15)
            node_data['target'] = energy_drain

            data[node] = node_data

        return data, env_data

    def create_windows(self, data, normalize=True):
        """Create sliding windows for each node."""
        windows = {'X': [], 'y': []}
        views = list(self.view_dims.keys())

        # Fit scalers if needed
        if normalize:
            scalers = {}
            for view in views:
                all_data = []
                for node in data:
                    all_data.append(data[node][view])
                view_data = np.concatenate(all_data, axis=0)
                scaler = StandardScaler()
                col_means = np.nanmean(view_data, axis=0)
                imputed_data = np.where(np.isnan(view_data), col_means, view_data)
                scaler.fit(imputed_data)
                scalers[view] = scaler

        for node in data:
            n_steps = len(data[node]['target'])

            for start_idx in range(0, n_steps - self.window_size - 100, 50):
                end_idx = start_idx + self.window_size

                window_data = []
                valid_window = True

                for view in views:
                    x = data[node][view][start_idx:end_idx].copy()

                    if np.isnan(x).mean() > 0.5:
                        valid_window = False
                        break

                    if np.any(np.isnan(x)):
                        col_means = np.nanmean(x, axis=0)
                        for c in range(x.shape[1]):
                            x[:, c] = np.where(np.isnan(x[:, c]), col_means[c], x[:, c])

                    if normalize:
                        x = scalers[view].transform(x)

                    window_data.append(x)

                if not valid_window:
                    continue

                mv_window = {view: window_data[i] for i, view in enumerate(views)}

                # Multi-horizon targets (in steps)
                # 15 min = 3 steps, 30 min = 6 steps, 60 min = 12 steps
                # 1 day = 288 steps, 7 days = 2016 steps
                targets = {}
                h_steps_map = {15: 3, 30: 6, 60: 12, 144: 288, 1008: 2016}
                for h in [15, 30, 60, 144, 1008]:
                    h_steps = h_steps_map.get(h, h)
                    target_idx = end_idx + h_steps
                    if target_idx < n_steps:
                        targets[h] = data[node]['target'][target_idx]
                    else:
                        targets[h] = data[node]['target'][-1]

                windows['X'].append(mv_window)
                windows['y'].append(targets)

        return windows

