# ## 5. Environment for Energy Management

# %%
class WSNEnergyEnv:
    """WSN Node Energy Management Environment with Bogor climate influence."""

    def __init__(self, env_data, node_id=0, max_steps=500):
        self.env_data = env_data
        self.node_id = node_id
        self.max_steps = min(max_steps, len(env_data['Tavg']))

        # Action space: 0=SLEEP, 1=LOW_POWER, 2=NORMAL, 3=TX, 4=HARVEST
        self.action_energy = {0: 0.01, 1: 0.03, 2: 0.08, 3: 0.15, 4: -0.05}

        self.reset()

    def reset(self):
        self.step_count = 0
        self.battery = 0.8
        self.queue = 0
        self.pdr = 1.0
        self.energy_consumed = 0
        return self._get_state()

    def _get_state(self):
        # Get current climate conditions
        temp = self.env_data['Tavg'][self.step_count % len(self.env_data['Tavg'])]
        humidity = self.env_data['H_avg'][self.step_count % len(self.env_data['H_avg'])]
        solar = self.env_data['H'][self.step_count % len(self.env_data['H'])]

        return np.array([
            self.battery,
            self.queue / 50.0,
            self.pdr,
            temp / 40.0,
            humidity / 100.0,
            solar / 30.0,
            self.step_count / self.max_steps
        ], dtype=np.float32)

    def step(self, action):
        # Energy consumption
        energy_used = self.action_energy.get(action, 0.05)
        self.battery = max(0, min(1, self.battery - energy_used))
        self.energy_consumed += max(0, energy_used)

        # Harvesting bonus from solar
        solar = self.env_data['H'][self.step_count % len(self.env_data['H'])]
        if action == 4:  # HARVEST action
            harvest_gain = 0.05 * (solar / 25)
            self.battery = min(1, self.battery + harvest_gain)

        # Traffic dynamics (influenced by time of day)
        hour_of_day = (self.step_count % 288) * 5 / 60  # 5 min steps
        day_factor = 0.5 + 0.5 * np.sin(2 * np.pi * hour_of_day / 24 - np.pi/2)

        if action == 3:  # TX
            self.queue = max(0, self.queue - 2)
            self.pdr = min(1, self.pdr + 0.02)
        else:
            # Packets arrive based on day factor and temperature
            temp = self.env_data['Tavg'][self.step_count % len(self.env_data['Tavg'])]
            arrival_rate = 0.3 * day_factor + 0.01 * (temp - 24)
            self.queue = min(50, self.queue + np.random.poisson(arrival_rate))
            self.pdr = max(0.5, self.pdr - 0.005)

        # Reward calculation
        w_E, w_P, w_Q, w_B = 0.4, 0.3, 0.2, 0.1

        energy_reward = -w_E * energy_used
        pdr_reward = w_P * self.pdr
        queue_penalty = -w_Q * (self.queue / 50)
        battery_penalty = -w_B * max(0, 0.2 - self.battery) * 5

        reward = energy_reward + pdr_reward + queue_penalty + battery_penalty

        self.step_count += 1
        done = self.step_count >= self.max_steps or self.battery <= 0.05

        if self.battery <= 0.05:
            reward -= 10

        return self._get_state(), reward, done

    def get_metrics(self):
        return {
            'battery': self.battery,
            'queue': self.queue,
            'pdr': self.pdr,
            'energy': self.energy_consumed
        }

