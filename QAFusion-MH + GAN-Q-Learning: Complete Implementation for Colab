def run_experiment():
    print("=" * 70)
    print("QAFusion-MH + GAN-Q-Learning Experiment")
    print("=" * 70)

    # Generate data
    print("\n[1] Generating Bogor climate-based WSN data...")
    data_gen = BogorDataGenerator(n_nodes=3, n_days=300, sampling_interval=5, window_size=96)
    data = data_gen.generate_all_data()
    windows = data_gen.create_windows(data)

    print(f"Generated {len(windows['X'])} windows")

    # Split data
    n_samples = len(windows['X'])
    train_windows = {'X': windows['X'][:int(0.7*n_samples)], 'y': windows['y'][:int(0.7*n_samples)]}
    val_windows = {'X': windows['X'][int(0.7*n_samples):int(0.85*n_samples)], 'y': windows['y'][int(0.7*n_samples):int(0.85*n_samples)]}
    test_windows = {'X': windows['X'][int(0.85*n_samples):], 'y': windows['y'][int(0.85*n_samples):]}

    print(f"Train: {len(train_windows['X'])}, Val: {len(val_windows['X'])}, Test: {len(test_windows['X'])}")

    # Initialize trainer
    print("\n[2] Initializing models...")
    trainer = Trainer(data_gen, state_dim=7, action_dim=5, hidden_dim=64)
    trainer.train_windows = train_windows
    trainer.val_windows = val_windows
    trainer.test_windows = test_windows

    # Train QAFusion-MH
    trainer.train_qafusion(train_windows, val_windows, epochs=15, batch_size=32)

    # Initialize environment
    print("\n[3] Initializing environment...")
    climate_data = {
        'temperature': data_gen.temperature,
        'humidity': data_gen.humidity,
        'solar': data_gen.solar,
        'sunshine': data_gen.sunshine,
        'traffic': data_gen.traffic
    }
    node_data = data[0]
    env = WSNEnergyEnv(climate_data, node_data, node_id=0, max_steps=300)

    # Collect transitions
    transitions = trainer.collect_transitions(env, n_episodes=15, max_steps=300)

    # Train GAN
    trainer.train_gan(transitions, epochs=20, batch_size=32)

    # Train policy
    trainer.train_policy(env, n_episodes=60, synthetic_interval=10, synthetic_count=200)

    # Evaluate
    returns, energies, pdrs, lifetimes = trainer.evaluate(env, n_episodes=15)

    print("\n" + "=" * 70)
    print("EXPERIMENT COMPLETE")
    print("=" * 70)

    return trainer, env, returns, energies, pdrs, lifetimes, test_windows

# Run experiment
trainer, env, returns, energies, pdrs, lifetimes, test_windows = run_experiment()

