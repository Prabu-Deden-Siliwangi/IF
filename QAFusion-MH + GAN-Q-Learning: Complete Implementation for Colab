# %%
class WSNEnergyEnv:
    """WSN Node Energy Management Environment"""

    def __init__(self, climate_data, node_data, node_id=0, max_steps=300):
        self.climate_data = climate_data
        self.node_data = node_data
        self.node_id = node_id
        self.max_steps = min(max_steps, len(node_data['target']))

        self.action_names = ['SLEEP', 'SENSE', 'TX', 'RELAY', 'HARVEST']
        self.action_energy = {0: 0.01, 1: 0.05, 2: 0.15, 3: 0.12, 4: -0.05}

        self.reset()

    def reset(self):
        self.step_count = 0
        self.battery = 0.8
        self.queue = 0
        self.pdr = 1.0
        self.total_energy = 0
        self.violations = 0
        return self._get_state()

    def _get_state(self):
        temp = self.climate_data['temperature'][self.step_count % len(self.climate_data['temperature'])]
        humidity = self.climate_data['humidity'][self.step_count % len(self.climate_data['humidity'])]
        solar = self.climate_data['solar'][self.step_count % len(self.climate_data['solar'])]

        return np.array([
            self.battery,
            self.queue / 50.0,
            self.pdr,
            temp / 40.0,
            humidity / 100.0,
            solar / 30.0,
            self.step_count / self.max_steps
        ], dtype=np.float32)

    def step(self, action):
        energy_used = self.action_energy.get(action, 0.05)
        self.battery = max(0, min(1, self.battery - energy_used))
        self.total_energy += max(0, energy_used)

        solar = self.climate_data['solar'][self.step_count % len(self.climate_data['solar'])]
        if action == 4:
            harvest_gain = 0.05 * (solar / 25)
            self.battery = min(1, self.battery + harvest_gain)

        hour_of_day = (self.step_count % 288) * 5 / 60
        day_factor = 0.5 + 0.5 * np.sin(2 * np.pi * hour_of_day / 24 - np.pi/2)

        if action in [2, 3]:
            self.queue = max(0, self.queue - 2)
            self.pdr = min(1, self.pdr + 0.02)
        else:
            arrival_rate = 0.3 * day_factor
            self.queue = min(50, self.queue + np.random.poisson(arrival_rate))
            self.pdr = max(0.5, self.pdr - 0.005)

        w_E, w_P, w_Q, w_B = 0.4, 0.3, 0.2, 0.1

        energy_reward = -w_E * energy_used
        pdr_reward = w_P * self.pdr
        queue_penalty = -w_Q * (self.queue / 50)
        battery_penalty = -w_B * max(0, 0.2 - self.battery) * 5

        reward = energy_reward + pdr_reward + queue_penalty + battery_penalty

        self.step_count += 1
        done = self.step_count >= self.max_steps or self.battery <= 0.05

        if self.battery <= 0.05:
            reward -= 10
            self.violations += 1

        return self._get_state(), reward, done

