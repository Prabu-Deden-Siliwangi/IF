# ## 6. GAN for Synthetic Experience

# %%
class ConditionalGAN(nn.Module):
    def __init__(self, state_dim, action_dim, hidden_dim=128):
        super().__init__()
        self.state_dim = state_dim
        self.action_dim = action_dim

        gen_input = state_dim + action_dim + 32
        self.generator = nn.Sequential(
            nn.Linear(gen_input, hidden_dim), nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim), nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim), nn.ReLU(),
            nn.Linear(hidden_dim, 1 + state_dim)
        )

        disc_input = state_dim + action_dim + 1 + state_dim
        self.discriminator = nn.Sequential(
            nn.Linear(disc_input, hidden_dim), nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, hidden_dim), nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, hidden_dim), nn.LeakyReLU(0.2),
            nn.Linear(hidden_dim, 1), nn.Sigmoid()
        )

    def _onehot(self, action, batch_size):
        action_onehot = torch.zeros(batch_size, self.action_dim).to(action.device)
        action_onehot.scatter_(1, action.unsqueeze(-1), 1)
        return action_onehot

    def generate(self, state, action):
        batch_size = state.shape[0]
        noise = torch.randn(batch_size, 32).to(state.device)
        action_onehot = self._onehot(action, batch_size)
        concat = torch.cat([state, action_onehot, noise], dim=-1)
        output = self.generator(concat)
        return output[:, 0], output[:, 1:]

    def discriminate(self, state, action, reward, next_state):
        batch_size = state.shape[0]
        action_onehot = self._onehot(action, batch_size)
        concat = torch.cat([state, action_onehot, reward.unsqueeze(-1), next_state], dim=-1)
        return self.discriminator(concat).squeeze(-1)

