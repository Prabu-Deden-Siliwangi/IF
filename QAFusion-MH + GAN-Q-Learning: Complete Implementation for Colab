# ## 3. QAFusion-MH Model (Section 4.2)

# %%
class ViewEncoder(nn.Module):
    """Per-view LSTM encoder"""
    def __init__(self, input_dim, hidden_dim=64):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True)
        self.fc = nn.Linear(hidden_dim, hidden_dim)

    def forward(self, x, mask=None):
        if mask is not None:
            x = x * mask.unsqueeze(-1)
        out, (h_n, _) = self.lstm(x)
        return self.fc(h_n[-1])


class QualityEstimator(nn.Module):
    """Estimate quality score per view"""
    def __init__(self, hidden_dim=64):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(hidden_dim + 4, 32),
            nn.ReLU(),
            nn.Linear(32, 16),
            nn.ReLU(),
            nn.Linear(16, 1),
            nn.Sigmoid()
        )

    def forward(self, h, quality_features):
        concat = torch.cat([h, quality_features], dim=-1)
        return self.net(concat).squeeze(-1)


class QualityGatedFusion(nn.Module):
    """Quality-gated fusion mechanism"""
    def __init__(self, n_views, hidden_dim=64):
        super().__init__()
        self.n_views = n_views
        self.gate = nn.ModuleList([
            nn.Sequential(
                nn.Linear(hidden_dim + 1, 32),
                nn.ReLU(),
                nn.Linear(32, 1)
            ) for _ in range(n_views)
        ])

    def forward(self, embeddings, quality_scores):
        batch_size = embeddings[0].shape[0]
        logits = []

        for i, (h, q) in enumerate(zip(embeddings, quality_scores)):
            concat = torch.cat([h, q.unsqueeze(-1)], dim=-1)
            logit = self.gate[i](concat).squeeze(-1)
            logits.append(logit)

        logits_stack = torch.stack(logits, dim=1)
        weights = torch.softmax(logits_stack, dim=1)

        fused = torch.zeros(batch_size, embeddings[0].shape[1]).to(embeddings[0].device)
        for i in range(self.n_views):
            fused = fused + weights[:, i:i+1] * embeddings[i]

        return fused, weights


class MultiHorizonHead(nn.Module):
    """Multi-horizon forecasting head"""
    def __init__(self, hidden_dim=64, n_horizons=5):
        super().__init__()
        self.n_horizons = n_horizons
        self.heads = nn.ModuleList([
            nn.Sequential(
                nn.Linear(hidden_dim, 32),
                nn.ReLU(),
                nn.Linear(32, 1)
            ) for _ in range(n_horizons)
        ])

    def forward(self, state):
        predictions = []
        for head in self.heads:
            predictions.append(head(state).squeeze(-1))
        return torch.stack(predictions, dim=-1)


class QAFusionMH(nn.Module):
    """Complete QAFusion-MH model"""
    def __init__(self, view_names, view_dims, hidden_dim=64, n_horizons=5):
        super().__init__()
        self.view_names = view_names
        self.n_views = len(view_names)
        self.hidden_dim = hidden_dim

        self.encoders = nn.ModuleDict({
            name: ViewEncoder(dim, hidden_dim)
            for name, dim in zip(view_names, view_dims)
        })

        self.quality_nets = nn.ModuleDict({
            name: QualityEstimator(hidden_dim)
            for name in view_names
        })

        self.fusion = QualityGatedFusion(self.n_views, hidden_dim)
        self.forecast_head = MultiHorizonHead(hidden_dim, n_horizons)

    def compute_quality_features(self, x, mask=None):
        batch_size, T, _ = x.shape

        if mask is not None:
            miss_ratio = (1 - mask).mean(dim=1)
        else:
            miss_ratio = torch.zeros(batch_size).to(x.device)

        recon_residual = torch.var(x.view(batch_size, -1), dim=1)
        recon_residual = torch.clamp(recon_residual / 0.5, 0, 1)

        x_flat = x.view(batch_size, -1)
        x_median = torch.median(x_flat, dim=1)[0]
        outlier_score = torch.abs(x_flat - x_median.unsqueeze(-1)).median(dim=1)[0]
        outlier_score = torch.clamp(outlier_score / 0.5, 0, 1)

        if T > 1:
            x_shifted = torch.cat([x[:, 1:, :], x[:, -1:, :]], dim=1)
            alignment = torch.abs(x - x_shifted).mean(dim=(1, 2))
            alignment = 1 - torch.clamp(alignment, 0, 1)
        else:
            alignment = torch.ones(batch_size).to(x.device)

        quality_features = torch.stack([miss_ratio, recon_residual, outlier_score, alignment], dim=1)
        return quality_features

    def forward(self, views, masks=None, return_all=False):
        batch_size = views[self.view_names[0]].shape[0]

        embeddings = []
        quality_scores = []

        for v_name in self.view_names:
            x = views[v_name]
            mask = masks.get(v_name, None) if masks is not None else None

            h = self.encoders[v_name](x, mask)
            embeddings.append(h)

            quality_features = self.compute_quality_features(x, mask)
            q = self.quality_nets[v_name](h, quality_features)
            quality_scores.append(q)

        state, weights = self.fusion(embeddings, quality_scores)
        predictions = self.forecast_head(state)

        if return_all:
            return state, predictions, weights, quality_scores
        return state, predictions

