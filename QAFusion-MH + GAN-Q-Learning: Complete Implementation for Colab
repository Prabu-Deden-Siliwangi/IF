# ## 2. Data Generator with Bogor Climate (Section 5.1-5.2)

# %%
class BogorDataGenerator:
    """Generate synthetic WSN data with real Bogor climate patterns"""

    def __init__(self, n_nodes=3, n_days=500, sampling_interval=5, window_size=96):
        self.n_nodes = n_nodes
        self.n_days = n_days
        self.sampling_interval = sampling_interval  # minutes
        self.window_size = window_size
        self.steps_per_day = 24 * 60 // sampling_interval  # 288 steps at 5-min
        self.n_steps = n_days * self.steps_per_day

        # Generate realistic Bogor climate patterns
        self._generate_climate_patterns()

        # View dimensions
        self.view_dims = {
            'battery': 3,   # voltage, current, SoC
            'traffic': 2,   # packet_rate, queue_length
            'link': 3,      # RSSI, LQI, PDR
            'mac': 2,       # duty_cycle, tx_power
            'env': 3        # temp, humidity, solar
        }

    def _generate_climate_patterns(self):
        """Generate synthetic but realistic Bogor climate data"""
        t = np.arange(self.n_steps)
        days = t / self.steps_per_day

        # Temperature: 23-29°C with seasonal pattern
        seasonal = 1.5 * np.sin(2 * np.pi * days / 365 - np.pi/2)
        diurnal_temp = 3.5 * np.sin(2 * np.pi * (t % self.steps_per_day) / self.steps_per_day - np.pi/2)
        self.temperature = 26 + seasonal + diurnal_temp + 0.5 * np.random.randn(self.n_steps)
        self.temperature = np.clip(self.temperature, 23, 29)

        # Humidity: 65-98%, inverse to temperature
        self.humidity = 85 - 8 * seasonal - 5 * diurnal_temp/3.5 + 3 * np.random.randn(self.n_steps)
        self.humidity = np.clip(self.humidity, 65, 98)

        # Solar radiation: 8-28 MJ/m²/day
        hour_of_day = (t % self.steps_per_day) * self.sampling_interval / 60
        diurnal_solar = np.sin(np.pi * (hour_of_day - 6) / 12)
        diurnal_solar = np.maximum(0, diurnal_solar)
        seasonal_solar = 8 * np.sin(2 * np.pi * days / 365)
        self.solar = 18 + seasonal_solar + 8 * diurnal_solar + 3 * np.random.randn(self.n_steps)
        self.solar = np.clip(self.solar, 8, 28)

        # Sunshine duration: 0-12 hours
        self.sunshine = 6 + 3 * diurnal_solar + 2 * np.random.randn(self.n_steps)
        self.sunshine = np.clip(self.sunshine, 0, 12)

        # Traffic intensity: 2-6 packets/hour
        self.traffic = 3.5 + 1.5 * diurnal_solar + 0.5 * np.random.randn(self.n_steps)
        self.traffic = np.clip(self.traffic, 2, 6)

    def generate_node_data(self, node_id):
        """Generate multi-view data for a single node"""
        t = np.arange(self.n_steps)
        hour_of_day = (t % self.steps_per_day) * self.sampling_interval / 60

        # Battery view
        base_soc = 0.8 + 0.1 * np.sin(2 * np.pi * t / self.steps_per_day)
        solar_charging = 0.3 * (self.solar / 25) * np.sin(np.pi * (hour_of_day - 6) / 12)
        solar_charging = np.maximum(0, solar_charging)
        soc = base_soc + solar_charging - 0.0003 * t / self.steps_per_day
        soc = np.clip(soc, 0.1, 1.0)

        voltage = 3.3 * soc + 0.05 * np.random.randn(self.n_steps)
        current = 10 + 8 * np.sin(2 * np.pi * hour_of_day / 24) + 3 * np.random.randn(self.n_steps)
        battery = np.column_stack([voltage, current, soc])

        # Traffic view
        arrival_rate = 0.5 + 0.8 * np.sin(np.pi * (hour_of_day - 8) / 16)**2
        arrival_rate += 0.05 * (self.temperature - 26)
        arrival_rate = np.maximum(0.1, arrival_rate)
        packet_rate = arrival_rate * 60
        queue_length = np.maximum(0, 5 + 3 * np.sin(2 * np.pi * hour_of_day / 24) + 2 * np.random.randn(self.n_steps))
        queue_length = np.minimum(50, queue_length)
        traffic = np.column_stack([packet_rate, queue_length])

        # Link quality view
        rssi = -65 - 0.2 * (self.humidity - 70) + 3 * np.random.randn(self.n_steps)
        lqi = 60 - 0.5 * (self.humidity - 70) + 5 * np.random.randn(self.n_steps)
        pdr = 0.95 - 0.01 * (self.humidity - 70) - 0.005 * packet_rate + 0.05 * np.random.randn(self.n_steps)
        pdr = np.clip(pdr, 0.7, 1.0)
        link = np.column_stack([rssi, lqi, pdr])

        # MAC view
        duty_cycle = 0.2 + 0.15 * (packet_rate / 50) + 0.1 * (self.solar / 25)
        duty_cycle = np.clip(duty_cycle, 0.05, 0.8)
        tx_power = 10 + 5 * (packet_rate / 50) + 2 * np.random.randn(self.n_steps)
        tx_power = np.clip(tx_power, 5, 20)
        mac = np.column_stack([duty_cycle, tx_power])

        # Environment view
        env = np.column_stack([self.temperature, self.humidity, self.solar])

        # Energy target
        energy_drain = 0.03 + 0.02 * (packet_rate / 50) + 0.01 * duty_cycle + 0.01 * np.random.randn(self.n_steps)
        energy_drain = np.clip(energy_drain, 0.01, 0.15)

        return {
            'battery': battery.astype(np.float32),
            'traffic': traffic.astype(np.float32),
            'link': link.astype(np.float32),
            'mac': mac.astype(np.float32),
            'env': env.astype(np.float32),
            'target': energy_drain.astype(np.float32)
        }

    def generate_all_data(self):
        """Generate data for all nodes"""
        data = {}
        for node in range(self.n_nodes):
            data[node] = self.generate_node_data(node)
        return data

    def create_windows(self, data, normalize=True):
        """Create sliding windows for training"""
        windows = {'X': [], 'y': []}
        views = list(self.view_dims.keys())

        # Collect all data for normalization
        if normalize:
            scalers = {}
            for view in views:
                all_data = []
                for node in data:
                    all_data.append(data[node][view])
                view_data = np.concatenate(all_data, axis=0)
                scaler = StandardScaler()
                col_means = np.nanmean(view_data, axis=0)
                imputed_data = np.where(np.isnan(view_data), col_means, view_data)
                scaler.fit(imputed_data)
                scalers[view] = scaler
        else:
            scalers = {view: None for view in views}

        for node in data:
            n_steps = len(data[node]['target'])

            for start_idx in range(0, n_steps - self.window_size - 200, 50):
                end_idx = start_idx + self.window_size

                window_data = []
                valid_window = True

                for view in views:
                    x = data[node][view][start_idx:end_idx].copy()

                    if np.isnan(x).mean() > 0.5:
                        valid_window = False
                        break

                    if np.any(np.isnan(x)):
                        col_means = np.nanmean(x, axis=0)
                        for c in range(x.shape[1]):
                            x[:, c] = np.where(np.isnan(x[:, c]), col_means[c], x[:, c])

                    if normalize and scalers[view] is not None:
                        x = scalers[view].transform(x)

                    window_data.append(x)

                if not valid_window:
                    continue

                mv_window = {view: window_data[i] for i, view in enumerate(views)}

                # Multi-horizon targets
                h_steps_map = {15: 3, 30: 6, 60: 12, 144: 288, 1008: 2016}
                targets = {}
                for h in [15, 30, 60, 144, 1008]:
                    h_steps = h_steps_map[h]
                    target_idx = end_idx + h_steps
                    if target_idx < n_steps:
                        targets[h] = data[node]['target'][target_idx]
                    else:
                        targets[h] = data[node]['target'][-1]

                windows['X'].append(mv_window)
                windows['y'].append(targets)

        return windows

