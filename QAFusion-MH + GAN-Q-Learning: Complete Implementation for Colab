# ## 7. Trainer Class

# %%
class Trainer:
    def __init__(self, data_generator, state_dim=7, action_dim=5, hidden_dim=64):
        self.data_generator = data_generator
        self.state_dim = state_dim
        self.action_dim = action_dim
        self.hidden_dim = hidden_dim

        self.view_names = list(data_generator.view_dims.keys())
        self.view_dims = list(data_generator.view_dims.values())

        self.qafusion = QAFusionMH(self.view_names, self.view_dims, hidden_dim, n_horizons=5).to(device)
        self.gan = ConditionalGAN(state_dim, action_dim, hidden_dim=128).to(device)
        self.agent = QLearningAgent(state_dim, action_dim, lr=0.1, gamma=0.95)

        self.replay_buffer = ReplayBuffer(max_size=10000)
        self.qafusion_optimizer = optim.Adam(self.qafusion.parameters(), lr=0.001)

        self.metrics = {'forecast_loss': [], 'returns': [], 'pdrs': [], 'energies': [], 'lifetimes': []}
        self.train_windows = None
        self.val_windows = None
        self.test_windows = None

    def train_qafusion(self, train_windows, val_windows, epochs=15, batch_size=32):
        print("=" * 60)
        print("Training QAFusion-MH...")
        print("=" * 60)

        n_samples = len(train_windows['X'])

        for epoch in range(epochs):
            self.qafusion.train()
            total_loss = 0
            n_batches = 0
            indices = np.random.permutation(n_samples)

            for start_idx in range(0, n_samples, batch_size):
                batch_indices = indices[start_idx:start_idx + batch_size]
                batch_views = {name: [] for name in self.view_names}
                batch_targets = []

                for idx in batch_indices:
                    window = train_windows['X'][idx]
                    target = train_windows['y'][idx]
                    for v_name in self.view_names:
                        batch_views[v_name].append(window[v_name])
                    target_list = [target.get(h, 0) for h in [15, 30, 60, 144, 1008]]
                    batch_targets.append(target_list)

                for v_name in self.view_names:
                    batch_views[v_name] = torch.tensor(np.stack(batch_views[v_name]), dtype=torch.float32).to(device)
                batch_targets = torch.tensor(np.stack(batch_targets), dtype=torch.float32).to(device)

                _, predictions = self.qafusion(batch_views)
                loss = nn.MSELoss()(predictions, batch_targets)

                self.qafusion_optimizer.zero_grad()
                loss.backward()
                self.qafusion_optimizer.step()

                total_loss += loss.item()
                n_batches += 1

            avg_loss = total_loss / max(n_batches, 1)
            self.metrics['forecast_loss'].append(avg_loss)

            if (epoch + 1) % 5 == 0:
                print(f"Epoch {epoch+1}/{epochs}, Loss: {avg_loss:.6f}")

        print("QAFusion-MH training complete!")

    def collect_transitions(self, env, n_episodes=15, max_steps=300):
        print("\n" + "=" * 60)
        print("Collecting Real Transitions...")
        print("=" * 60)

        transitions = []

        for episode in range(n_episodes):
            state = env.reset()
            episode_return = 0
            episode_pdr = 0

            for step in range(max_steps):
                action = self.agent.select_action(state)
                next_state, reward, done = env.step(action)

                transitions.append((state.copy(), action, reward, next_state.copy()))
                self.replay_buffer.add(state, action, reward, next_state, is_synthetic=False)
                self.agent.update(state, action, reward, next_state)

                episode_return += reward
                episode_pdr += env.pdr
                state = next_state

                if done:
                    break

            self.agent.decay_epsilon()
            self.metrics['returns'].append(episode_return)
            self.metrics['pdrs'].append(episode_pdr / max_steps)

            if (episode + 1) % 5 == 0:
                print(f"Episode {episode+1}/{n_episodes}, Return: {episode_return:.1f}")

        print(f"Collected {len(transitions)} transitions")
        return transitions

    def train_gan(self, transitions, epochs=20, batch_size=32):
        print("\n" + "=" * 60)
        print("Training GAN...")
        print("=" * 60)

        if len(transitions) < batch_size:
            print(f"Warning: Only {len(transitions)} transitions available")
            return

        g_optimizer = optim.Adam(self.gan.generator.parameters(), lr=0.001)
        d_optimizer = optim.Adam(self.gan.discriminator.parameters(), lr=0.001)

        for epoch in range(epochs):
            batch = random.sample(transitions, min(batch_size, len(transitions)))
            states = torch.tensor(np.stack([b[0] for b in batch]), dtype=torch.float32).to(device)
            actions = torch.tensor([b[1] for b in batch], dtype=torch.long).to(device)
            rewards = torch.tensor([b[2] for b in batch], dtype=torch.float32).to(device)
            next_states = torch.tensor(np.stack([b[3] for b in batch]), dtype=torch.float32).to(device)

            for _ in range(2):
                d_optimizer.zero_grad()
                real_out = self.gan.discriminate(states, actions, rewards, next_states)
                d_real_loss = -torch.log(real_out + 1e-8).mean()
                fake_reward, fake_next_state = self.gan.generate(states, actions)
                fake_out = self.gan.discriminate(states, actions, fake_reward.detach(), fake_next_state.detach())
                d_fake_loss = -torch.log(1 - fake_out + 1e-8).mean()
                d_loss = d_real_loss + d_fake_loss
                d_loss.backward()
                d_optimizer.step()

            g_optimizer.zero_grad()
            fake_reward, fake_next_state = self.gan.generate(states, actions)
            fake_out = self.gan.discriminate(states, actions, fake_reward, fake_next_state)
            g_loss = -torch.log(fake_out + 1e-8).mean()
            g_loss.backward()
            g_optimizer.step()

            if (epoch + 1) % 10 == 0:
                print(f"Epoch {epoch+1}/{epochs}, G Loss: {g_loss.item():.4f}, D Loss: {d_loss.item():.4f}")

        print("GAN training complete!")

    def generate_synthetic(self, n_samples=200, quality_threshold=0.6, beta=2.0):
        synthetic_added = 0

        for _ in range(n_samples):
            if len(self.replay_buffer.buffer) > 0:
                sample = random.choice(list(self.replay_buffer.buffer))
                state = torch.tensor(sample['state'], dtype=torch.float32).unsqueeze(0).to(device)
                action = torch.tensor([sample['action']]).to(device)

                with torch.no_grad():
                    fake_reward, fake_next_state = self.gan.generate(state, action)
                    d_out = self.gan.discriminate(state, action, fake_reward, fake_next_state)
                    quality = 1 / (1 + np.exp(-beta * (d_out.item() - 0.5)))

                    if quality > quality_threshold:
                        self.replay_buffer.add(
                            sample['state'], sample['action'],
                            fake_reward.item(), fake_next_state.squeeze().cpu().numpy(),
                            is_synthetic=True, quality=quality
                        )
                        synthetic_added += 1

        print(f"Added {synthetic_added}/{n_samples} synthetic transitions (quality > {quality_threshold})")
        return synthetic_added

    def train_policy(self, env, n_episodes=60, synthetic_interval=10, synthetic_count=200):
        print("\n" + "=" * 60)
        print("Training Policy with Quality-Controlled Replay...")
        print("=" * 60)

        for episode in range(n_episodes):
            if episode > 0 and episode % synthetic_interval == 0:
                self.generate_synthetic(n_samples=synthetic_count, quality_threshold=0.6)

            state = env.reset()
            episode_return = 0
            episode_energy = 0
            episode_pdr = 0

            for step in range(env.max_steps):
                action = self.agent.select_action(state)
                next_state, reward, done = env.step(action)

                self.replay_buffer.add(state, action, reward, next_state, is_synthetic=False)

                if len(self.replay_buffer) > 32:
                    states, actions, rewards, next_states, is_synthetic, qualities = self.replay_buffer.sample(32)
                    for i in range(len(states)):
                        weight = 1.0 if not is_synthetic[i] else qualities[i]
                        self.agent.update(states[i], actions[i], rewards[i], next_states[i], weight=weight)
                else:
                    self.agent.update(state, action, reward, next_state)

                episode_return += reward
                episode_energy += env.total_energy
                episode_pdr += env.pdr
                state = next_state

                if done:
                    break

            self.agent.decay_epsilon()
            self.metrics['returns'].append(episode_return)
            self.metrics['energies'].append(episode_energy)
            self.metrics['pdrs'].append(episode_pdr / env.max_steps)
            self.metrics['lifetimes'].append(env.step_count)

            if (episode + 1) % 20 == 0:
                avg_return = np.mean(self.metrics['returns'][-20:]) if len(self.metrics['returns']) >= 20 else episode_return
                print(f"Episode {episode+1}/{n_episodes}, Return: {avg_return:.1f}, Buffer: {len(self.replay_buffer)}")

        print("Policy training complete!")
        return self.metrics

    def evaluate(self, env, n_episodes=15):
        print("\n" + "=" * 60)
        print("Evaluating Policy...")
        print("=" * 60)

        returns = []
        energies = []
        pdrs = []
        lifetimes = []

        for episode in range(n_episodes):
            state = env.reset()
            episode_return = 0
            episode_energy = 0
            episode_pdr = 0
            step_count = 0

            for step in range(env.max_steps):
                action = self.agent.select_action(state, greedy=True)
                next_state, reward, done = env.step(action)

                episode_return += reward
                episode_energy += env.total_energy
                episode_pdr += env.pdr
                step_count += 1
                state = next_state

                if done:
                    break

            returns.append(episode_return)
            energies.append(episode_energy)
            pdrs.append(episode_pdr / max(step_count, 1))
            lifetimes.append(step_count)

        print(f"Avg Return: {np.mean(returns):.1f} ± {np.std(returns):.1f}")
        print(f"Avg PDR: {np.mean(pdrs):.3f} ± {np.std(pdrs):.3f}")
        print(f"Avg Lifetime: {np.mean(lifetimes):.0f} ± {np.std(lifetimes):.0f}")

        return returns, energies, pdrs, lifetimes

